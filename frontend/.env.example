# DeepFocus frontend environment variables.
# Copy this file to .env.local and override as needed.
# Vite exposes variables prefixed with VITE_ to the client bundle.

# Base URL for the backend API. Leave empty to use the Vite dev proxy
# (which forwards /api to http://localhost:8000 in development).
# In production builds served by Django, leave this empty so /api is same-origin.
VITE_API_BASE_URL=
