# DeepFocus backend environment variables.
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.

# Required in production; defaults to an insecure placeholder for local dev.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# "true" enables Django debug mode. Must be "false" in production.
DEBUG=true

# Comma-separated list of hostnames Django will accept.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of origins allowed for cross-origin API requests.
# Only needed when frontend is served from a different origin (local dev).
# In production the frontend is served by Django itself, so this is ignored.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
